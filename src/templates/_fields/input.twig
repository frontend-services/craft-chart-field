{#
  data-* attributes are NOT touched by Craft's namespaceInputs(),
  so we use them exclusively for JS targeting.
  name="{{ name }}" uses the raw field handle — Craft adds fields[] automatically.
#}
<div
    class="chart-field-input"
    data-chart-field
    data-allow-custom-colors="{{ allowCustomColors ? '1' : '0' }}"
    data-show-advanced="{{ showAdvancedOptions ? '1' : '0' }}"
    data-default-palette="{{ defaultPalette | json_encode | e('html_attr') }}"
    {% if showLivePreview %}
    data-show-preview="1"
    data-chart-library="{{ chartLibrary }}"
    data-preview-js-assets="{{ previewJsAssets | json_encode | e('html_attr') }}"
    {% if previewNoLicense %}data-preview-no-license="1"{% endif %}
    {% endif %}
>

    {# Hidden input — name is the raw handle; Craft's namespaceInputs adds fields[] #}
    <input
        type="hidden"
        class="js-chart-field-value"
        name="{{ name }}"
        value="{{ existingJson | e('html_attr') }}"
    >

    {# License key warning #}
    {% if showLicenseWarning %}
        <div class="chart-field-input__warning">
            <span data-icon="alert" aria-hidden="true"></span>
            {{ 'This field uses HighCharts which requires a commercial license. Charts will show a watermark until a license key is added in'|t('chart-field') }}
            <a href="{{ cpUrl('settings/plugins/chart-field') }}">{{ 'plugin settings'|t('chart-field') }}</a>.
        </div>
    {% endif %}

    {# === Panel 1: Chart Type === #}
    <div class="chart-field-panel chart-field-panel--type">
        <div class="chart-field-type-row">
            <span class="chart-field-label">{{ 'Chart Type'|t('chart-field') }}</span>
            <div class="chart-field-type-select">
                <button type="button" class="btn menubtn js-chart-type-btn">
                    <span class="chart-field-type-picker__icon js-chart-type-icon"></span>
                    <span class="js-chart-type-label">{{ 'Select type…'|t('chart-field') }}</span>
                </button>
                <div class="menu chart-field-type-menu">
                    <ul>
                        {% for type in allowedChartTypes %}
                            <li>
                                <a data-type="{{ type }}" data-label="{{ chartTypeLabels[type] ?? type }}">
                                    <span class="chart-field-type-picker__icon">{{ (chartTypeIcons[type] ?? '') | raw }}</span>
                                    {{ chartTypeLabels[type] ?? type }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {# Title / Subtitle #}
    <div class="chart-field-panel chart-field-panel--meta">
        <div class="chart-field-axes-grid">
            <div class="chart-field-field-row">
                <label class="chart-field-label">{{ 'Title'|t('chart-field') }}</label>
                <input type="text" class="text fullwidth" data-cf="title" placeholder="{{ 'Chart title (optional)'|t('chart-field') }}">
            </div>
            <div class="chart-field-field-row">
                <label class="chart-field-label">{{ 'Subtitle'|t('chart-field') }}</label>
                <input type="text" class="text fullwidth" data-cf="subtitle" placeholder="{{ 'Subtitle (optional)'|t('chart-field') }}">
            </div>
        </div>
    </div>

    {# === Panel 2: Axes === #}
    <div class="chart-field-panel chart-field-panel--axes js-axes-panel">
        <div class="chart-field-axes-grid">
            <div class="chart-field-axis-group">
                <h4 class="chart-field-panel__heading">{{ 'X Axis'|t('chart-field') }}</h4>
                <div class="chart-field-field-row">
                    <label class="chart-field-label">{{ 'Label'|t('chart-field') }}</label>
                    <input type="text" class="text fullwidth" data-cf="xaxis-label" placeholder="{{ 'e.g. Month'|t('chart-field') }}">
                </div>
            </div>
            <div class="chart-field-axis-group">
                <h4 class="chart-field-panel__heading">{{ 'Y Axis'|t('chart-field') }}</h4>
                <div class="chart-field-field-row">
                    <label class="chart-field-label">{{ 'Label'|t('chart-field') }}</label>
                    <input type="text" class="text fullwidth" data-cf="yaxis-label" placeholder="{{ 'e.g. Revenue (€)'|t('chart-field') }}">
                </div>
                <div class="chart-field-field-row chart-field-field-row--inline">
                    <div>
                        <label class="chart-field-label">{{ 'Min'|t('chart-field') }}</label>
                        <input type="number" class="text" data-cf="yaxis-min" style="width:80px;" placeholder="auto">
                    </div>
                    <div>
                        <label class="chart-field-label">{{ 'Max'|t('chart-field') }}</label>
                        <input type="number" class="text" data-cf="yaxis-max" style="width:80px;" placeholder="auto">
                    </div>
                    <div>
                        <label class="chart-field-label">{{ 'Suffix'|t('chart-field') }}</label>
                        <input type="text" class="text" data-cf="yaxis-suffix" style="width:80px;" placeholder="€">
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# === Panel 3: Series Data === #}
    <div class="chart-field-panel chart-field-panel--series">
        <h3 class="chart-field-panel__heading">{{ 'Data'|t('chart-field') }}</h3>
        <div class="js-chart-grid chart-field-grid-container"></div>
    </div>


    {# === Panel 4: Live Preview === #}
    {% if showLivePreview %}
        <div class="chart-field-panel chart-field-panel--preview">
            <h3 class="chart-field-panel__heading">{{ 'Preview'|t('chart-field') }}</h3>
            {% if previewNoLicense %}
                <p class="chart-field-preview__notice">
                    {{ 'Preview shown without license. Charts will show a watermark until a license key is added in'|t('chart-field') }}
                    <a href="{{ cpUrl('settings/plugins/chart-field') }}">{{ 'plugin settings'|t('chart-field') }}</a>.
                </p>
            {% endif %}
            <div class="js-preview-container chart-field-preview__container">
                <p class="chart-field-preview__placeholder">{{ 'Select a chart type and add data to see a preview.'|t('chart-field') }}</p>
            </div>
        </div>
    {% endif %}

    {# === Panel 5: Advanced Options === #}
    {% if showAdvancedOptions %}
        <div class="chart-field-panel chart-field-panel--advanced">
            <h3 class="chart-field-panel__heading">{{ 'Styling & Options'|t('chart-field') }}</h3>
            <div class="chart-field-field-row chart-field-field-row--toggles">
                <label class="chart-field-toggle">
                    <input type="checkbox" data-cf="legend-enabled" checked>
                    {{ 'Show legend'|t('chart-field') }}
                </label>
                <div class="select">
                    <select data-cf="legend-position">
                        <option value="bottom">{{ 'Bottom'|t('chart-field') }}</option>
                        <option value="top">{{ 'Top'|t('chart-field') }}</option>
                        <option value="left">{{ 'Left'|t('chart-field') }}</option>
                        <option value="right">{{ 'Right'|t('chart-field') }}</option>
                    </select>
                </div>
            </div>
            <div class="chart-field-field-row chart-field-field-row--toggles">
                <label class="chart-field-toggle">
                    <input type="checkbox" data-cf="tooltip-enabled" checked>
                    {{ 'Show tooltip'|t('chart-field') }}
                </label>
                <label class="chart-field-toggle">
                    <input type="checkbox" data-cf="tooltip-shared">
                    {{ 'Shared tooltip'|t('chart-field') }}
                </label>
            </div>
            <hr style="margin:12px 0;border:none;border-top:1px solid var(--hairline-color,#e3e5e8);">
            <div class="chart-field-field-row chart-field-field-row--inline">
                <div>
                    <label class="chart-field-label">{{ 'Value prefix'|t('chart-field') }}</label>
                    <input type="text" class="text" data-cf="value-prefix" style="width:90px;" placeholder="{{ '$, £, …'|t('chart-field') }}">
                </div>
                <div>
                    <label class="chart-field-label">{{ 'Value suffix'|t('chart-field') }}</label>
                    <input type="text" class="text" data-cf="value-suffix" style="width:90px;" placeholder="{{ '€, %, kg, …'|t('chart-field') }}">
                </div>
            </div>
        </div>
    {% endif %}


</div>
