{
    "name": "frontend-services/craft-chart-field",
    "description": "A Chart Field plugin for Craft CMS — store and render charts using Chart.js, HighCharts, or ApexCharts.",
    "type": "craft-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Frontend Services",
            "homepage": "https://github.com/frontend-services"
        }
    ],
    "require": {
        "craftcms/cms": "^5.0.0"
    },
    "autoload": {
        "psr-4": {
            "chartfield\\": "src/"
        }
    },
    "extra": {
        "name": "Chart Field",
        "handle": "chart-field",
        "class": "chartfield\\Plugin",
        "minCraftVersion": "5.0.0",
        "developer": "Frontend Services",
        "developerUrl": "https://frontend.services",
        "description": "A custom field type for creating charts with Chart.js, HighCharts, and ApexCharts.",
        "documentationUrl": "https://github.com/frontend-services/craft-chart-field",
        "changelogUrl": "https://raw.githubusercontent.com/frontend-services/craft-chart-field/master/CHANGELOG.md"
    }
}
